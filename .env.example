# =============================================================================
# Real-Time Analytics Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and modify values for your environment.
#   cp .env.example .env
# =============================================================================

# ----- Application -----------------------------------------------------------
ENVIRONMENT=development                          # development | staging | production
LOG_LEVEL=DEBUG                                  # DEBUG | INFO | WARNING | ERROR | FATAL
DEBUG=true                                       # Enable debug mode (auto-reload, verbose errors)
HOST=0.0.0.0                                     # Bind address for the HTTP server
PORT=8000                                        # Port for the HTTP server
WORKERS=4                                        # Number of uvicorn worker processes
APP_VERSION=1.0.0                                # Application version (semver)

# ----- Database (TimescaleDB / PostgreSQL) ----------------------------------
DATABASE_PROVIDER=timescaledb                    # timescaledb | postgresql | clickhouse
DATABASE_HOST=localhost                          # Database hostname
DATABASE_PORT=5432                               # Database port
DATABASE_NAME=analytics                          # Database name
DATABASE_USER=analytics                          # Database user
DATABASE_PASSWORD=analytics                      # Database password (change in production!)
DATABASE_POOL_SIZE=10                            # Connection pool size
DATABASE_POOL_OVERFLOW=20                        # Max overflow connections
DATABASE_POOL_TIMEOUT=30                         # Pool timeout in seconds
DATABASE_MIN_CONNECTIONS=5                       # Minimum connections in pool
DATABASE_MAX_CONNECTIONS=20                      # Maximum connections in pool
DATABASE_ECHO=false                              # Log all SQL queries

# ----- Redis -----------------------------------------------------------------
REDIS_HOST=localhost                             # Redis hostname
REDIS_PORT=6379                                  # Redis port
REDIS_DB=0                                       # Redis database number
REDIS_PASSWORD=                                  # Redis password (leave empty for none)
REDIS_SSL=false                                  # Use SSL for Redis connection
REDIS_STREAM_MAXLEN=100000                       # Max stream length for event streams
REDIS_CONSUMER_GROUP=analytics-group             # Consumer group name for Redis Streams

# ----- Kafka (alternative queue provider) -----------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092           # Kafka bootstrap servers
KAFKA_TOPIC=analytics-events                     # Kafka topic for events
KAFKA_CONSUMER_GROUP=analytics-consumer          # Kafka consumer group
KAFKA_PARTITIONS=6                               # Number of Kafka topic partitions
KAFKA_REPLICATION_FACTOR=3                       # Kafka replication factor
KAFKA_MAX_POLL_RECORDS=500                       # Max records per poll
KAFKA_SESSION_TIMEOUT_MS=30000                   # Session timeout in milliseconds

# ----- Queue Provider --------------------------------------------------------
QUEUE_PROVIDER=redis_streams                     # redis_streams | kafka

# ----- Authentication & Security ---------------------------------------------
JWT_SECRET=super-secret-key-change-in-production # JWT signing secret (MUST change in production!)
JWT_ALGORITHM=HS256                              # JWT signing algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=15                   # Access token TTL in minutes
REFRESH_TOKEN_EXPIRE_DAYS=7                      # Refresh token TTL in days
BCRYPT_ROUNDS=12                                 # bcrypt cost factor (>=12 for production)

# ----- Rate Limiting ---------------------------------------------------------
RATE_LIMIT_ENABLED=true                          # Enable rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60                # Max requests per minute per user/IP
RATE_LIMIT_BURST_SIZE=100                        # Burst size for rate limiter

# ----- CORS ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080  # Comma-separated allowed origins
CORS_ALLOW_CREDENTIALS=true                      # Allow credentials in CORS
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS  # Allowed HTTP methods
CORS_ALLOW_HEADERS=*                             # Allowed HTTP headers

# ----- Data Retention --------------------------------------------------------
RETENTION_RAW_EVENTS_DAYS=30                     # Retention period for raw events
RETENTION_AGGREGATED_HOURLY_DAYS=90              # Retention period for hourly aggregations
RETENTION_AGGREGATED_DAILY_DAYS=365              # Retention period for daily aggregations
RETENTION_CHECKPOINT_INTERVAL=3600               # Checkpoint interval in seconds

# ----- Sampling --------------------------------------------------------------
SAMPLING_DEFAULT_RATE=1.0                        # Default sampling rate (1.0 = 100%)
SAMPLING_HIGH_VOLUME_THRESHOLD=10000             # Events/sec threshold for high volume
SAMPLING_HIGH_VOLUME_RATE=0.1                    # Sampling rate when threshold exceeded

# ----- Event Processing ------------------------------------------------------
MAX_EVENT_SIZE_BYTES=65536                       # Max event payload size (64KB)
BATCH_SIZE=100                                   # Batch size for event processing
FLUSH_INTERVAL_SECONDS=1.0                       # Flush interval for batch processing

# ----- Observability: Tracing (OpenTelemetry) --------------------------------
TRACING_ENABLED=true                             # Enable distributed tracing
TRACING_SERVICE_NAME=analytics-pipeline          # Service name for traces
TRACING_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces  # OTLP HTTP exporter endpoint
TRACING_SAMPLE_RATE=0.1                          # Trace sampling rate (0.0 - 1.0)

# ----- Observability: Metrics (Prometheus) -----------------------------------
METRICS_ENABLED=true                             # Enable Prometheus metrics endpoint
METRICS_PORT=9090                                # Metrics HTTP server port

# ----- PostgreSQL Connection String (read-only replica / reporting) ----------
DATABASE_READONLY_HOST=                          # Read-only replica host (optional)
DATABASE_READONLY_PORT=5432                      # Read-only replica port
DATABASE_READONLY_USER=                          # Read-only replica user
DATABASE_READONLY_PASSWORD=                      # Read-only replica password
